#version 460
#extension GL_EXT_mesh_shader : require

// Trigger-mode trace geometry, drawn directly from the shared gap-aware sample ring.
// Each dispatch draws one contiguous *present* run of a triggered capture (the CPU
// builds the runs, so this shader never bridges a hole). Samples are read from the
// ring with wrap; x is trigger-relative — window_pos = window_pos0 + local_index,
// mapped through the visible window via x_range — so overlaying many captures into
// the additive accumulator builds the persistence/eye picture. The box/line switch
// is the spc LOD: box mode when a segment is sub-pixel (spc > 2).
//
// Geometry (miter joints / box splat) is identical to waveform_renderer.mesh; only
// the sample fetch and the x mapping differ.

const uint WORKGROUP_SIZE           = 32;
const uint VERTICES_PER_INVOCATION  = 8;
const uint TRIANGLES_PER_INVOCATION = 7;

const uint BOX_VERTICES_PER_INVOCATION  = 4;
const uint BOX_TRIANGLES_PER_INVOCATION = 2;

layout(local_size_x = WORKGROUP_SIZE, local_size_y = 1, local_size_z = 1) in;
layout(triangles,
       max_vertices   = VERTICES_PER_INVOCATION  * WORKGROUP_SIZE,
       max_primitives = TRIANGLES_PER_INVOCATION * WORKGROUP_SIZE) out;

layout(push_constant) uniform PC {
    vec2  x_range;        // visible window fraction [x_min, x_max] in [0,1]
    vec2  y_range;        // amplitude window
    vec2  viewport_ratio; // (height/width, width/height)
    float line_width;
    uint  ring_capacity;  // C
    uint  run_phys_start; // physical ring index of this run's first sample
    uint  n_segments;     // segments in this run (samples - 1)
    uint  viewport_width;
    float min_weight;
    float window_len;     // L (samples) — x maps over [0, L-1]
    float window_pos0;    // trigger-relative sample position of the run's first sample
} pc;

layout(std430, binding = 0) readonly buffer Ring {
    float samples[];
};

layout(location = 0) out struct Varying {
    vec2 texCoord;
} v_out[];

float ring_sample(uint local_idx) {
    return samples[(pc.run_phys_start + local_idx) % pc.ring_capacity];
}

// Trigger-relative window position → isometric screen space.
vec2 signal_to_screen(uint local_idx, float y_val) {
    float window_pos = pc.window_pos0 + float(local_idx);
    float x_norm     = window_pos / max(pc.window_len - 1.0, 1.0);
    float sx = ((x_norm - pc.x_range.x) / (pc.x_range.y - pc.x_range.x) * 2.0 - 1.0)
               * pc.viewport_ratio.y;
    float sy = -((y_val - pc.y_range.x) / (pc.y_range.y - pc.y_range.x) * 2.0 - 1.0);
    return vec2(sx, sy);
}

vec4 screen_to_clip(vec2 s) {
    return vec4(s * vec2(pc.viewport_ratio.x, 1.0), 0.0, 1.0);
}

void main() {
    const uint wg_start   = gl_WorkGroupID.x * WORKGROUP_SIZE;
    const uint li         = gl_LocalInvocationID.x;
    const uint local_segs = wg_start >= pc.n_segments ? 0u
                          : min(pc.n_segments - wg_start, WORKGROUP_SIZE);

    // spc = (window_len-1)*x_span / viewport_width; box when spc > 2.
    float pixels_per_segment = float(pc.viewport_width)
        / (max(pc.window_len - 1.0, 1.0) * (pc.x_range.y - pc.x_range.x));
    bool box_mode = pixels_per_segment < 0.5;

    if (li == 0) {
        uint verts = box_mode ? BOX_VERTICES_PER_INVOCATION * local_segs
                              : VERTICES_PER_INVOCATION     * local_segs;
        uint prims = box_mode ? BOX_TRIANGLES_PER_INVOCATION * local_segs
                              : TRIANGLES_PER_INVOCATION     * local_segs;
        SetMeshOutputsEXT(verts, prims);
    }

    if (li >= local_segs)
        return;

    const uint i = wg_start + li;          // local segment index within the run

    vec2 a = signal_to_screen(i,     ring_sample(i    ));
    vec2 b = signal_to_screen(i + 1, ring_sample(i + 1));

    if (box_mode) {
        float x_mid = 0.5 * (a.x + b.x);
        float y_top = min(a.y, b.y) - pc.line_width;
        float y_bot = max(a.y, b.y) + pc.line_width;

        uint vo = BOX_VERTICES_PER_INVOCATION * li;
        gl_MeshVerticesEXT[vo + 0].gl_Position = screen_to_clip(vec2(x_mid - pc.line_width, y_top));
        gl_MeshVerticesEXT[vo + 1].gl_Position = screen_to_clip(vec2(x_mid + pc.line_width, y_top));
        gl_MeshVerticesEXT[vo + 2].gl_Position = screen_to_clip(vec2(x_mid - pc.line_width, y_bot));
        gl_MeshVerticesEXT[vo + 3].gl_Position = screen_to_clip(vec2(x_mid + pc.line_width, y_bot));

        float dy     = abs(a.y - b.y);
        float weight = max(pc.min_weight, pc.line_width / max(pc.line_width, dy));
        v_out[vo + 0].texCoord = vec2(weight, -1.0);
        v_out[vo + 1].texCoord = vec2(weight,  1.0);
        v_out[vo + 2].texCoord = vec2(weight, -1.0);
        v_out[vo + 3].texCoord = vec2(weight,  1.0);

        uint to = BOX_VERTICES_PER_INVOCATION  * li;
        uint bo = BOX_TRIANGLES_PER_INVOCATION * li;
        gl_PrimitiveTriangleIndicesEXT[bo + 0] = to + uvec3(0, 1, 2);
        gl_PrimitiveTriangleIndicesEXT[bo + 1] = to + uvec3(1, 3, 2);
        return;
    }

    const uint ic = min(i + 2, pc.n_segments); // last sample index == n_segments
    vec2 c = signal_to_screen(ic, ring_sample(ic));

    if (i > 0)              a = 0.5 * (b - a) + a;
    if (i + 2 <= pc.n_segments) c = 0.5 * (b - c) + c;

    vec2 ab = (b - a) * inversesqrt(dot(b - a, b - a));
    vec2 cb = (b - c) * inversesqrt(dot(b - c, b - c));

    bool  benddir = ab.x * cb.y - ab.y * cb.x < 0.0;
    float bendfac = benddir ? -1.0 : 1.0;

    vec2 pa = bendfac * pc.line_width * vec2(-ab.y,  ab.x);
    vec2 pb = bendfac * pc.line_width * vec2( cb.y, -cb.x);

    uint vo = VERTICES_PER_INVOCATION * li;
    gl_MeshVerticesEXT[vo + 0].gl_Position = screen_to_clip(a + pa);
    gl_MeshVerticesEXT[vo + 1].gl_Position = screen_to_clip(a - pa);
    gl_MeshVerticesEXT[vo + 2].gl_Position = screen_to_clip(b + pa);

    float beta = acos(clamp(-dot(ab, cb), -1.0, 1.0));
    float d    = pc.line_width * clamp(1.0 / cos(beta * 0.5), -4.0, 4.0);
    gl_MeshVerticesEXT[vo + 3].gl_Position = screen_to_clip(b - d * normalize(pa + pb));

    gl_MeshVerticesEXT[vo + 4].gl_Position = screen_to_clip(b);
    gl_MeshVerticesEXT[vo + 5].gl_Position = screen_to_clip(b + pb);
    gl_MeshVerticesEXT[vo + 6].gl_Position = screen_to_clip(c - pb);
    gl_MeshVerticesEXT[vo + 7].gl_Position = screen_to_clip(c + pb);

    v_out[vo + 0].texCoord = vec2(1.0,  1.0);
    v_out[vo + 1].texCoord = vec2(1.0, -1.0);
    v_out[vo + 2].texCoord = vec2(1.0,  1.0);
    v_out[vo + 3].texCoord = vec2(1.0, -1.0);
    v_out[vo + 4].texCoord = vec2(1.0,  0.0);
    v_out[vo + 5].texCoord = vec2(1.0,  1.0);
    v_out[vo + 6].texCoord = vec2(1.0, -1.0);
    v_out[vo + 7].texCoord = vec2(1.0,  1.0);

    uint to = VERTICES_PER_INVOCATION  * li;
    uint bo = TRIANGLES_PER_INVOCATION * li;

    if (benddir) {
        gl_PrimitiveTriangleIndicesEXT[bo + 0] = to + uvec3(0, 1, 2);
        gl_PrimitiveTriangleIndicesEXT[bo + 1] = to + uvec3(2, 1, 4);
        gl_PrimitiveTriangleIndicesEXT[bo + 2] = to + uvec3(4, 1, 3);
        gl_PrimitiveTriangleIndicesEXT[bo + 3] = to + uvec3(5, 2, 4);
        gl_PrimitiveTriangleIndicesEXT[bo + 4] = to + uvec3(5, 6, 7);
        gl_PrimitiveTriangleIndicesEXT[bo + 5] = to + uvec3(5, 4, 6);
        gl_PrimitiveTriangleIndicesEXT[bo + 6] = to + uvec3(4, 3, 6);
    } else {
        gl_PrimitiveTriangleIndicesEXT[bo + 0] = to + uvec3(0, 2, 1);
        gl_PrimitiveTriangleIndicesEXT[bo + 1] = to + uvec3(2, 4, 1);
        gl_PrimitiveTriangleIndicesEXT[bo + 2] = to + uvec3(4, 3, 1);
        gl_PrimitiveTriangleIndicesEXT[bo + 3] = to + uvec3(5, 4, 2);
        gl_PrimitiveTriangleIndicesEXT[bo + 4] = to + uvec3(5, 7, 6);
        gl_PrimitiveTriangleIndicesEXT[bo + 5] = to + uvec3(5, 6, 4);
        gl_PrimitiveTriangleIndicesEXT[bo + 6] = to + uvec3(4, 6, 3);
    }
}
