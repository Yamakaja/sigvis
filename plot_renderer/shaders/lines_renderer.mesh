#version 460
#extension GL_EXT_mesh_shader : require
#extension GL_EXT_debug_printf : enable

const uint WORKGROUP_SIZE = 32;
const uint VERTICES_PER_INVOCATION = 8;
const uint TRIANGLES_PER_INVOCATION = 7;

layout(local_size_x = WORKGROUP_SIZE, local_size_y = 1, local_size_z = 1) in;
layout(triangles,
       max_vertices  = VERTICES_PER_INVOCATION  * WORKGROUP_SIZE,
       max_primitives = TRIANGLES_PER_INVOCATION * WORKGROUP_SIZE) out;

layout(push_constant) uniform PC {
    vec2  center;
    vec2  zoom;
    vec2  viewport_ratio;
    float line_width;
    uint  n_samples;
    uint  n_samples_per_trace;
    uint  trace_offset;
} pc;

struct Vertex {
    vec2 position;
};

layout(std430, binding = 0) readonly buffer VertexBuffer {
    Vertex vertices[];
};

layout(location = 0) out struct Varying {
    vec2 texCoord;
} v_out[];

// viewport_ratio = (height/width, width/height)
// Isometric space: x scaled by width/height so both axes = height/2 px per unit.
// Y is negated for Vulkan (clip y points down).
vec2 world_to_screen(vec2 x) {
    return pc.zoom * vec2(pc.viewport_ratio.y, -1.0) * (x - pc.center);
}

// Isometric → clip: undo the x scaling.
vec4 screen_to_clip(vec2 x) {
    return vec4(x * vec2(pc.viewport_ratio.x, 1.0), 0.0, 1.0);
}

void main() {
    const uint i_trace        = gl_WorkGroupID.x + pc.trace_offset;
    const uint i_trace_sample = gl_WorkGroupID.y * WORKGROUP_SIZE + gl_LocalInvocationID.x;
    const uint li             = gl_LocalInvocationID.x;

    if (i_trace_sample >= pc.n_samples_per_trace - 2)
        return;

    const uint local_segments = min(pc.n_samples_per_trace - 2 - i_trace_sample,
                                    WORKGROUP_SIZE);

    if (li == 0)
        SetMeshOutputsEXT(VERTICES_PER_INVOCATION  * local_segments,
                          TRIANGLES_PER_INVOCATION * local_segments);

    const uint i = i_trace * pc.n_samples_per_trace + i_trace_sample;

    if (i >= pc.n_samples)
        return;

    vec2 a = vertices[i    ].position;
    vec2 b = vertices[i + 1].position;
    vec2 c = vertices[i + 2].position;

    if (i_trace_sample > 0)           a = 0.5 * (b - a) + a;
    if (i_trace_sample < pc.n_samples_per_trace - 2) c = 0.5 * (b - c) + c;

    a = world_to_screen(a);
    b = world_to_screen(b);
    c = world_to_screen(c);

    vec2 ab = (b - a) * inversesqrt(dot(b - a, b - a));
    vec2 cb = (b - c) * inversesqrt(dot(b - c, b - c));

    bool  benddir = ab.x * cb.y - ab.y * cb.x < 0.0;
    float bendfac = benddir ? -1.0 : 1.0;

    vec2 pa = bendfac * pc.line_width * vec2(-ab.y,  ab.x);
    vec2 pb = bendfac * pc.line_width * vec2( cb.y, -cb.x);

    uint vo = VERTICES_PER_INVOCATION * li;
    gl_MeshVerticesEXT[vo + 0].gl_Position = screen_to_clip(a + pa);
    gl_MeshVerticesEXT[vo + 1].gl_Position = screen_to_clip(a - pa);
    gl_MeshVerticesEXT[vo + 2].gl_Position = screen_to_clip(b + pa);

    float beta = acos(clamp(-dot(ab, cb), -1.0, 1.0));
    float d    = pc.line_width * clamp(1.0 / cos(beta * 0.5), -4.0, 4.0);
    gl_MeshVerticesEXT[vo + 3].gl_Position = screen_to_clip(b - d * normalize(pa + pb));

    gl_MeshVerticesEXT[vo + 4].gl_Position = screen_to_clip(b);
    gl_MeshVerticesEXT[vo + 5].gl_Position = screen_to_clip(b + pb);
    gl_MeshVerticesEXT[vo + 6].gl_Position = screen_to_clip(c - pb);
    gl_MeshVerticesEXT[vo + 7].gl_Position = screen_to_clip(c + pb);

    v_out[vo + 0].texCoord = vec2(1.0,  1.0);
    v_out[vo + 1].texCoord = vec2(1.0, -1.0);
    v_out[vo + 2].texCoord = vec2(1.0,  1.0);
    v_out[vo + 3].texCoord = vec2(1.0, -1.0);
    v_out[vo + 4].texCoord = vec2(1.0,  0.0);
    v_out[vo + 5].texCoord = vec2(1.0,  1.0);
    v_out[vo + 6].texCoord = vec2(1.0, -1.0);
    v_out[vo + 7].texCoord = vec2(1.0,  1.0);

    uint to = VERTICES_PER_INVOCATION  * li;
    uint bo = TRIANGLES_PER_INVOCATION * li;

    if (benddir) {
        gl_PrimitiveTriangleIndicesEXT[bo + 0] = to + uvec3(0, 1, 2);
        gl_PrimitiveTriangleIndicesEXT[bo + 1] = to + uvec3(2, 1, 4);
        gl_PrimitiveTriangleIndicesEXT[bo + 2] = to + uvec3(4, 1, 3);
        gl_PrimitiveTriangleIndicesEXT[bo + 3] = to + uvec3(5, 2, 4);
        gl_PrimitiveTriangleIndicesEXT[bo + 4] = to + uvec3(5, 6, 7);
        gl_PrimitiveTriangleIndicesEXT[bo + 5] = to + uvec3(5, 4, 6);
        gl_PrimitiveTriangleIndicesEXT[bo + 6] = to + uvec3(4, 3, 6);
    } else {
        gl_PrimitiveTriangleIndicesEXT[bo + 0] = to + uvec3(0, 2, 1);
        gl_PrimitiveTriangleIndicesEXT[bo + 1] = to + uvec3(2, 4, 1);
        gl_PrimitiveTriangleIndicesEXT[bo + 2] = to + uvec3(4, 3, 1);
        gl_PrimitiveTriangleIndicesEXT[bo + 3] = to + uvec3(5, 4, 2);
        gl_PrimitiveTriangleIndicesEXT[bo + 4] = to + uvec3(5, 7, 6);
        gl_PrimitiveTriangleIndicesEXT[bo + 5] = to + uvec3(5, 6, 4);
        gl_PrimitiveTriangleIndicesEXT[bo + 6] = to + uvec3(4, 6, 3);
    }

}